# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# AWS Bedrock (for LangChain/LangGraph)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Application
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO
